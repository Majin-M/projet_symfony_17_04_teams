{% extends 'base.html.twig' %}

{% block title %}Hello InscriptionController!{% endblock %}

{% block body %}
<!-- vue de du formulaire d'inscription 
 le css du formulaire vient de bootstrap
 
dans config/packages/twig.yaml 
twig:
    file_name_pattern: '*.twig'
    form_themes: ['bootstrap_5_layout.html.twig']
le lien cdn de bootstrap a été ajouté dans base.html.twig
-->
<style>
    .example-wrapper {
        margin: 1em auto;
        max-width: 800px;
        width: 95%;
        font: 18px/1.5 sans-serif;
    }

    .example-wrapper code {
        background: #F5F5F5;
        padding: 2px 6px;
    }
</style>

<div class="example-wrapper">
    <h1>Page d'inscription</h1>
    <!-- form est une fonction de Twig qui permet de créer un formulaire HTML
    register est le nom du formulaire qui a été créé dans src/Controller/InscriptionController.php -->
    {{form(register)}}

</div>
{% endblock %}