{% extends 'base.html.twig' %}

{% block title %}Hello ProfileController!{% endblock %}

{% block body %}
<!-- vue du profil de l'utilisateur -->
<!-- c 'est elle qui s'affiche quand l'utilisateur est connecté grace à la route /profile dans son controleur-->
<!-- les personnes non connectées ne peuvent pas accéder à cette page -->
<!-- l'accès est sécurisé grace à la configurtion  - { path: ^/profile, roles: ROLE_USER } dans config/packages/security.yaml  -->
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h1>Bienvenue dans l'espace membre!</h1>

      {% if app.user %}
    <div class="mb-3">
        <!-- affichage de l'utilisateur connecté -->
        <!-- app.user.userIdentifier renvoie l'identifiant de l'utilisateur connecté -->
        <!-- logout_path() renvoie le chemin d'accès à la page de déconnexion -->
        <!-- deconnexion est le nom du bouton de déconnexion -->
        vous êtes connecté en tant que {{ app.user.lastname }}, <a href="{{ logout_path() }}">deconnexion</a>
    </div>
    {% endif %}
</div>
{% endblock %}
