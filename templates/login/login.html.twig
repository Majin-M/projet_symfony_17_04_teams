{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}
<!-- vue de du formulaire de connexion  
 le css du formulaire vient de bootstrap
 
dans config/packages/twig.yaml 
twig:
    file_name_pattern: '*.twig'
    form_themes: ['bootstrap_5_layout.html.twig']
le lien cdn de bootstrap a été ajouté dans base.html.twig
-->
<form method="post">
    <!-- affichage d'une erreur d'authentification -->
    {% if error %}
    <!-- error.messageKey renvoie la clé de traduction de l'erreur -->
    <!-- error.messageData renvoie les données de traduction de l'erreur -->
    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}



    <h1 class="h3 mb-3 font-weight-normal">Please sign in</h1>
    <!-- formulaire de connexion -->
    <!-- _username et _password sont les noms des champs de formulaire par défaut par Symfony SecurityBundle -->
    <label for="username">Email</label>
    <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control"
        autocomplete="email" required autofocus>
    <label for="password">Password</label>
    <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>
    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

    {#
    Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
    See https://symfony.com/doc/current/security/remember_me.html

    <div class="checkbox mb-3">
        <input type="checkbox" name="_remember_me" id="_remember_me">
        <label for="_remember_me">Remember me</label>
    </div>
    #}

    <button class="btn btn-lg btn-primary" type="submit">
        Sign in
    </button>
</form>
{% endblock %}